# ─────────────────────────────────────────
# Supabase (required)
# TODO: Copy values from your Supabase project > Settings > API
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (previously "anon key") — safe to expose in browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Service role key — server-side only, NEVER expose to the browser
# TODO: Rotate this key periodically via Supabase dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────
# Webhook & Cron security
# ─────────────────────────────────────────
# TODO: Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace-with-random-32-byte-hex
CRON_SECRET=replace-with-random-32-byte-hex

# ─────────────────────────────────────────
# Payment provider (optional — implement plugin)
# ─────────────────────────────────────────
# TODO: Add Stripe or Square keys when implementing plugins/payments
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────
# App URL
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
